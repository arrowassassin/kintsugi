{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kintsugi Control Room",
  "version": "0.2.1",
  "identifier": "dev.kintsugi.control-room",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "trunk serve",
    "beforeBuildCommand": "trunk build --release"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Kintsugi Control Room",
        "width": 1100,
        "height": 720,
        "minWidth": 760,
        "minHeight": 520,
        "theme": null
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'wasm-unsafe-eval'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
